PORT=3001

# Example env for apps/api (no compartir valores reales)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/acustica-sounds?retryWrites=true&w=majority
MONGODB_DB_NAME=acustica-sounds
JWT_SECRET=change_me_access
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_EXPIRES_IN=7d

# CORS
API_ALLOWED_ORIGINS=http://localhost:3000
PLAYBACK_ALLOWED_ORIGINS=http://localhost:3000

# Video playback provider (Incremento 2)
VIDEO_PROVIDER=mux
MUX_SIGNING_KEY_ID=
# Opciones de secreto:
# - Valor crudo directo de Mux (p.ej. MUX_SIGNING_KEY_SECRET=sk_live_123)
# - Prefijo base64: cuando se provee codificado (MUX_SIGNING_KEY_SECRET=base64:c2tfbGl2ZV8xMjM=)
MUX_SIGNING_KEY_SECRET=
MUX_SIGNED_TTL=120
MUX_PLAYBACK_BASE=https://stream.mux.com
PLAYBACK_RATELIMIT_PER_MIN=30

# E2E helpers
E2E_MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/acustica-sounds-test?retryWrites=true&w=majority
E2E_MUX_PLAYBACK_ID=
